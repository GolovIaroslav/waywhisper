# PipeWire/PulseAudio source. Use pactl list short sources to pick another mic.
WAYWHISPER_MIC=@DEFAULT_SOURCE@

# Model/runtime.
WAYWHISPER_MODEL=large-v3-turbo
WAYWHISPER_DEVICE=auto
WAYWHISPER_COMPUTE_TYPE=auto
# WAYWHISPER_LANGUAGE=ru

# Output: clipboard pastes with ydotool, copy only leaves text in the clipboard.
WAYWHISPER_PASTE_MODE=clipboard

# Stop the daemon after each transcription to free VRAM/RAM.
WAYWHISPER_EXIT_AFTER_TRANSCRIBE=false

# Recording/transcription tuning.
WAYWHISPER_STOP_TAIL_SECONDS=1.0
WAYWHISPER_WAV_END_SILENCE_SECONDS=1.0
WAYWHISPER_CHUNK_LENGTH=30
WAYWHISPER_VAD_FILTER=false
WAYWHISPER_VAD_THRESHOLD=0.3
WAYWHISPER_VAD_MIN_SILENCE_MS=900
WAYWHISPER_VAD_SPEECH_PAD_MS=500
WAYWHISPER_CONDITION_ON_PREVIOUS_TEXT=false
